# Copy this file to `.env` and fill in your key. `.env` is gitignored.
#   cp .env.example .env

OPENAI_API_KEY=sk-...

# Optional overrides (uncomment to use)
# OPENAI_MODEL=gpt-5.4-mini

# Override pricing used for the cost estimate ($ per 1M tokens). If unset, rates
# come from the live LiteLLM price registry, then the script's offline fallback.
# PRICE_INPUT=0.75
# PRICE_OUTPUT=4.50
